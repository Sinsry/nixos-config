{
  // "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/master/doc/json_schema.json",
  "display": {
    "separator": "",
    "bar": {
      "width": 15,
      "char": {
        "elapsed": "■",
        "total": "-"
      }
    }
  },
  // "logo": {
  //   "source": "/etc/nixos/asset/Gruul.png",
  //   "type": "kitty",
  //   "width": 20,
  //   "padding": {
  //     "left": 3,
  //     "top": 1
  //   }
  "logo": {
    "type": "command-raw",
    "source": "echo -e \"\\e[36m$(toilet -f future $(hostname))\\e[0m\"",
    "padding": {
      "left": 2,
      "top": 1
    }
  },
  "modules": [
    "break",
    {
      "type": "os",
      "key": "  "
    },
    {
      "type": "kernel",
      "key": "  "
    },
    {
      "type": "custom",
      "format": ""
    },
    {
      "type": "cpu",
      "key": "  ",
      "format": "{1} - {3}C/{4}T"
    },
    {
      "type": "gpu",
      "key": "󰾲  ",
      "format": "{2}",
      "hideType": "unknown"
    },
    {
      "type": "custom",
      "format": ""
    },
    {
      "type": "memory",
      "key": "  "
    },
    {
      "type": "swap",
      "key": "󰾵  "
    },
    {
      "type": "custom",
      "format": ""
    },
    {
      "type": "disk",
      "key": "  ",
      "folders": [
        "/"
      ],
      "format": "{1} / {2} ({3})"
    },
    {
      "type": "disk",
      "key": "  ",
      "folders": [
        "/home/sinsry/Jeux"
      ],
      "format": "{1} / {2} ({3})"
    },
    // {
    //   "type": "disk",
    //   "key": "   ",
    //   "folders": [
    //     "/home/sinsry/Jeux"
    //   ],
    //   "percent": {
    //     "type": 6
    //   }
    // },
    {
      "type": "custom",
      "format": ""
    },
    {
      "type": "command",
      "key": "󰖂  ",
      "text": "ip addr show $HOSTNAME 2>/dev/null | awk '/inet 10/{print $2}' | cut -d'/' -f1 || echo 'N/A'"
    },
    {
      "type": "command",
      "key": "󱦂  ",
      "text": "ip=$(hostname -I 2>/dev/null | awk '{print $1}'); [ -z \"$ip\" ] && echo \"N/A\" || echo \"$ip\""
    },
    {
      "type": "command",
      "key": "  ",
      "text": "curl -s --connect-timeout 1 'ip-api.com/json' | jq -r '\"\\(.query) (\\(.countryCode))\"' 2>/dev/null || echo 'N/A'"
    },
    {
      "type": "custom",
      "format": ""
    },
    {
      "type": "command",
      "key": "  ",
      "text": "d=$(stat -c %w / | cut -d' ' -f1); days=$(( ( $(date +%s) - $(date -d \"$d\" +%s) ) / 86400 )); echo \"$d\" | awk -F'-' '{print $3\"/\"$2\"/\"$1\" - '\"$days\"' jours\"}'"
    }
    // "format": "{1}{2}{3}{4}{5}{6}{7}{8}"
  ]
}